# URL de conexão com o MongoDB (usando Replica Set para suporte a transações)
DATABASE_URL=mongodb://user:password@mongodb:27017/tek_system?authSource=admin&replicaSet=rs0&directConnection=true

# Segredo usado para assinar o JWT de acesso (troque por uma string forte em produção)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Tempo de expiração do access token
JWT_EXPIRES_IN=1d

# Segredo usado para assinar o JWT de refresh (troque por uma string forte em produção)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Tempo de expiração do refresh token
JWT_REFRESH_EXPIRES_IN=7d

# Porta em que a aplicação irá rodar
PORT=3000
